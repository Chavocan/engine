{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aetherforge.local/schemas/v1/observation.schema.json",
  "title": "Observation",
  "type": "object",
  "required": ["schema_version", "tick", "run_id", "message", "rng_draw", "world"],
  "properties": {
    "schema_version": { "type": "string" },
    "tick": { "type": "integer", "minimum": 0 },
    "run_id": { "type": "string" },
    "message": { "type": "string" },
    "rng_draw": { "type": "integer", "minimum": 0 },
    "world": {
      "type": "object",
      "required": ["world_version", "entities"],
      "properties": {
        "world_version": { "type": "string" },
        "entities": {
          "type": "array",
          "items": {}
        }
      },
      "additionalProperties": true
    },
    "farm": {
      "type": "object",
      "description": "Optional farm slice when server is built with Rust feature `farm-stub`. Omitted in default builds.",
      "required": ["day", "time_minutes", "plots", "inventory"],
      "properties": {
        "day": { "type": "integer", "minimum": 1 },
        "time_minutes": { "type": "integer", "minimum": 0 },
        "plots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["coord", "crop", "growth_stage"],
            "properties": {
              "coord": {
                "type": "object",
                "required": ["x", "y"],
                "properties": {
                  "x": { "type": "integer" },
                  "y": { "type": "integer" }
                },
                "additionalProperties": false
              },
              "crop": { "type": "string" },
              "growth_stage": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "inventory": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
